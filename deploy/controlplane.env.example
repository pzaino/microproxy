# Control-plane authentication configuration
#
# Production: keep development mode disabled and configure API keys and/or JWTs.
MICROPROXY_DEVELOPMENT_MODE=false
MICROPROXY_CONTROLPLANE_API_KEYS=replace-with-strong-api-key
MICROPROXY_CONTROLPLANE_JWTS=

# Development-only mode (do not use in production):
# MICROPROXY_DEVELOPMENT_MODE=true
# MICROPROXY_CONTROLPLANE_API_KEYS=
# MICROPROXY_CONTROLPLANE_JWTS=
# Default key in development mode: microproxy-controlplane-dev-key
